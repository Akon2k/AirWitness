@page "/maintenance/stations"
@using Sentinel.Dashboard.Services
@using Sentinel.Dashboard.Models.Data
@* @attribute [Authorize] *@
@inject RadioConfigService ConfigService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Sentinel.Dashboard.Services.ThemeService Theme
@rendermode InteractiveServer

<div class="maintenance-container">

    <main class="main-content">
        <header class="content-header">
            <div class="header-info">
                <h1 class="gradient-text">Bóveda de Datos</h1>
                <p>Configuración persistente de la red de monitoreo y persistencia SQL.</p>
            </div>
            <div class="header-actions">
                <button class="btn-neon generic" @onclick="ExportJson">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    RESPALDO JSON
                </button>
                <button class="btn-neon" @onclick="() => isAddModalOpen = true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    NUEVO MEDIO
                </button>
            </div>
        </header>

        @if (isLoading)
        {
            <div class="loader-overlay">
                <div class="spinner"></div>
                <span>Sincronizando con PostgreSQL...</span>
            </div>
        }
        else
        {
            <div class="table-card frosted-glass">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;"></th>
                            <th>MEDIO</th>
                            <th>UBICACIÓN</th>
                            <th>DIAL</th>
                            <th>FLUJO DE DATOS</th>
                            <th style="text-align: right;">GESTIÓN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var station in stations)
                        {
                            <tr>
                                <td style="padding-right: 0;">
                                    <div class="avatar-minimal">@(!string.IsNullOrEmpty(station.Name) ? station.Name[0].ToString().ToUpper() : "R")</div>
                                </td>
                                <td>
                                    <div class="media-info-minimal">
                                        <span class="name">@station.Name</span>
                                        <span class="category">@station.Category</span>
                                    </div>
                                </td>
                                <td class="text-dim">@station.City</td>
                                <td><span class="freq-badge-minimal">@station.Frequency</span></td>
                                <td>
                                    <div class="url-minimal-container" title="@station.StreamUrl">
                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path></svg>
                                        <span class="url-text">@station.StreamUrl</span>
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    <div class="minimal-actions-group">
                                        <button class="btn-icon-minimal" @onclick="() => EditStation(station)" title="Configurar">
                                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </button>
                                        <button class="btn-icon-minimal accent" @onclick="() => OpenScheduleModal(station)" title="Horarios">
                                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                        </button>
                                        <button class="btn-icon-minimal danger" @onclick="() => DeleteStation(station)" title="Remover">
                                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </main>
</div>

@if (isAddModalOpen || editingStation != null)
{
    <div class="modal-overlay">
        <div class="modal-card frosted-glass animate-in">
            <div class="modal-header">
                <h2>@(editingStation != null ? "Editar Estación" : "Nueva Estación de Radio")</h2>
                <button class="btn-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Nombre del Medio</label>
                        <input type="text" @bind="model.Name" class="neon-input" placeholder="Ej: Radio Infinita" />
                    </div>
                    <div class="form-group">
                        <label>FUENTE STREAMING</label>
                        <input type="text" @bind="model.StreamUrl" class="neon-input" placeholder="http://..." />
                    </div>
                    <div class="form-group">
                        <label>Ciudad</label>
                        <input type="text" @bind="model.City" class="neon-input" placeholder="Santiago" />
                    </div>
                    <div class="form-group">
                        <label>Frecuencia / Dial</label>
                        <input type="text" @bind="model.Frequency" class="neon-input" placeholder="100.1 FM" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-neon gray" @onclick="CloseModal">CANCELAR</button>
                <button class="btn-neon" @onclick="SaveStation">@(editingStation != null ? "ACTUALIZAR" : "GUARDAR EN DB")</button>
            </div>
        </div>
    </div>
}

@if (isScheduleModalOpen && selectedStationForSchedule != null)
{
    <div class="sentinel-modal-overlay">
        <div class="schedule-timeline-modal animate-in">
            <div class="modal-header-premium">
                <div class="header-titles">
                    <h2>Programación: <span class="text-accent">@selectedStationForSchedule.Name</span></h2>
                    <p class="subtitle">Configuración persistente en Base de Datos.</p>
                </div>
                <button class="btn-close-circle" @onclick="() => isScheduleModalOpen = false">&times;</button>
            </div>

            <div class="timeline-container-premium">
                <div class="timeline-scroll">
                    @for (int h = 6; h < 24; h++)
                    {
                        var hour = h;
                        var isActive = stationSchedules.Any(s => s.StartTime.Hour == hour);
                        <div class="timeline-block @(isActive ? "active" : "")" @onclick="() => ToggleHourSelection(hour)">
                            <div class="block-time">@(hour.ToString("D2")):00</div>
                            <div class="block-slot">
                                @if (isActive) { <div class="check-mark">✓</div> }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer-premium">
                <div class="status-summary">
                    <span class="status-pulse"></span>
                    Hitos registrados: <strong class="text-accent">@stationSchedules.Count</strong> bloques de 1 hora en DB.
                </div>
                <div class="footer-actions">
                    <button class="btn-premium-close" @onclick="() => isScheduleModalOpen = false">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

@if (isDeleteConfirmOpen && stationToDelete != null)
{
    <div class="sentinel-modal-overlay">
        <div class="confirm-modal animate-in">
            <div class="confirm-content">
                <div class="confirm-icon danger">
                    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"></path><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </div>
                <h3>¿Confirmar Eliminación?</h3>
                <p>Estás a punto de remover <span class="text-accent">@stationToDelete.Name</span>. Los datos históricos y horarios se perderán.</p>
            </div>
            <div class="confirm-actions">
                <button class="btn-confirm-cancel" @onclick="() => isDeleteConfirmOpen = false">CANCELAR</button>
                <button class="btn-confirm-danger" @onclick="ConfirmDelete">ELIMINAR MEDIO</button>
            </div>
        </div>
    </div>
}

@code {
    private List<RadioTask> stations = new();
    private bool isLoading = true;
    private bool isAddModalOpen = false;
    private bool isScheduleModalOpen = false;
    private RadioTask? editingStation = null;
    private RadioTask? selectedStationForSchedule = null;
    private List<MonitoringSchedule> stationSchedules = new();
    private RadioTask model = new();
    private bool isDeleteConfirmOpen = false;
    private RadioTask? stationToDelete = null;
    
    // Form fields for new schedule
    private DateTime newScheduleStart = DateTime.Today.AddHours(9);
    private DateTime newScheduleEnd = DateTime.Today.AddHours(10);

    protected override async Task OnInitializedAsync()
    {
        Theme.OnThemeChanged += StateHasChanged;
        await LoadStations();
    }

    private async Task LoadStations()
    {
        isLoading = true;
        stations = await ConfigService.LoadConfigAsync();
        isLoading = false;
    }

    private void EditStation(RadioTask station)
    {
        editingStation = station;
        model = new RadioTask
        {
            Id = station.Id,
            Name = station.Name,
            StreamUrl = station.StreamUrl,
            City = station.City,
            Region = station.Region,
            Frequency = station.Frequency,
            Category = station.Category,
            MasterPath = station.MasterPath
        };
    }

    private async Task SaveStation()
    {
        await ConfigService.SaveStationAsync(model);
        CloseModal();
        await LoadStations();
    }

    private void DeleteStation(RadioTask station)
    {
        stationToDelete = station;
        isDeleteConfirmOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (stationToDelete != null)
        {
            await ConfigService.DeleteStationAsync(stationToDelete.Id);
            isDeleteConfirmOpen = false;
            stationToDelete = null;
            await LoadStations();
        }
    }

    private void CloseModal()
    {
        isAddModalOpen = false;
        editingStation = null;
        model = new RadioTask();
    }

    private async Task OpenScheduleModal(RadioTask station)
    {
        selectedStationForSchedule = station;
        isScheduleModalOpen = true;
        await LoadSchedules();
    }

    private async Task LoadSchedules()
    {
        if (selectedStationForSchedule != null && int.TryParse(selectedStationForSchedule.Id, out int id))
        {
            stationSchedules = await ConfigService.GetSchedulesAsync(id);
        }
    }

    private async Task ToggleHourSelection(int hour)
    {
        if (selectedStationForSchedule != null && int.TryParse(selectedStationForSchedule.Id, out int stationId))
        {
            var existing = stationSchedules.FirstOrDefault(s => s.StartTime.Hour == hour);
            
            if (existing != null)
            {
                // Unchecked: Delete
                await ConfigService.DeleteScheduleAsync(existing.Id);
            }
            else
            {
                // Checked: Add 10-minute block for that hour
                var sch = new MonitoringSchedule
                {
                    RadioStationId = stationId,
                    StartTime = new TimeOnly(hour, 0),
                    EndTime = new TimeOnly(hour, 59),
                    IsActive = true
                };
                await ConfigService.SaveScheduleAsync(sch);
            }
            
            await LoadSchedules();
        }
    }

    private async Task ExportJson()
    {
        var path = await ConfigService.ExportToJsonAsync();
        await JS.InvokeVoidAsync("alert", $"Configuración respaldada en: {path}");
    }
}
