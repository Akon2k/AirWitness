@page "/audit"
@using Microsoft.EntityFrameworkCore
@using Sentinel.Dashboard.Data
@using Sentinel.Dashboard.Models.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject Sentinel.Dashboard.Services.ThemeService Theme
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="audit-panel-container @(Theme.IsLightMode ? "light-mode" : "")">
    <header class="content-header">
        <div class="header-info">
            <h1 class="gradient-text">Panel de Auditoría</h1>
            <p>Historial ejecutivo de detecciones y testigos (testigos acústicos con contexto).</p>
        </div>
        <div class="header-actions">
            <button class="btn-neon generic" @onclick="LoadRecords">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"></path><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                REFRESCAR
            </button>
        </div>
    </header>

    @if (records == null)
    {
        <div class="loader-overlay">
            <div class="spinner"></div>
            <span>Consultando registros en PostgreSQL...</span>
        </div>
    }
    else
    {
        <div class="table-card frosted-glass animate-in">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>FECHA / HORA</th>
                        <th>MEDIO</th>
                        <th>COMERCIAL</th>
                        <th>FIABILIDAD</th>
                        <th style="text-align: right;">TESTIGO</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!records.Any())
                    {
                        <tr>
                            <td colspan="5" class="empty-row">No se han registrado detecciones automáticas aún.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var record in records)
                        {
                            <tr>
                                <td class="text-dim">@record.DetectionTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>
                                    <div class="media-info">
                                        <span class="name">@record.RadioStation?.Name</span>
                                        <span class="location">@record.RadioStation?.City</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="master-info">
                                        <span class="title">@record.MasterAudio?.Title</span>
                                        <span class="duration">@(record.MasterAudio?.Duration.ToString("N1") ?? "0")s</span>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var conf = record.Confidence * 100;
                                        var colorClass = conf > 90 ? "high" : conf > 70 ? "mid" : "low";
                                    }
                                    <div class="confidence-badge @colorClass">
                                        @conf.ToString("N0")%
                                    </div>
                                </td>
                                <td style="text-align: right;">
                                    @if (!string.IsNullOrEmpty(record.EvidenceFileName))
                                    {
                                        <div class="action-group">
                                            <a href="/evidencia/@record.EvidenceFileName" target="_blank" class="btn-icon-minimal accent" title="Escuchar">
                                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                                            </a>
                                            <a href="/evidencia/@record.EvidenceFileName" download class="btn-icon-minimal" title="Descargar MP3">
                                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="no-evidence">Sin testigo</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<MatchRecord>? records = null;

    protected override async Task OnInitializedAsync()
    {
        Theme.OnThemeChanged += StateHasChanged;
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        records = await db.MatchRecords
            .Include(m => m.RadioStation)
            .Include(m => m.MasterAudio)
            .OrderByDescending(m => m.DetectionTime)
            .Take(100)
            .ToListAsync();
    }
}

<style>
    .audit-panel-container {
        padding: 2rem;
        font-family: 'Outfit', sans-serif;
        color: var(--text-main);
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 3rem;
    }

    .header-info h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        letter-spacing: -1px;
    }

    .header-info h1.gradient-text {
        background: linear-gradient(to right, #fff, var(--text-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .light-mode .header-info h1.gradient-text {
        background: none;
        -webkit-text-fill-color: initial;
        color: var(--text-main);
    }

    .table-card {
        background: var(--bg-card);
        border-radius: 20px;
        border: 1px solid var(--border-color);
        overflow: hidden;
        box-shadow: var(--shadow-soft);
    }

    .premium-table {
        width: 100%;
        border-collapse: collapse;
    }

    .premium-table th {
        background: var(--bg-inner);
        padding: 1.25rem 1.5rem;
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: left;
    }

    .premium-table td {
        padding: 1.25rem 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .media-info, .master-info {
        display: flex;
        flex-direction: column;
    }

    .media-info .name, .master-info .title {
        font-weight: 700;
        color: var(--text-main);
    }

    .media-info .location, .master-info .duration {
        font-size: 0.75rem;
        color: var(--text-dim);
    }

    .confidence-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 800;
    }

    .confidence-badge.high { background: rgba(0, 242, 255, 0.1); color: var(--text-accent); border: 1px solid var(--text-accent); }
    .confidence-badge.mid { background: rgba(255, 204, 0, 0.1); color: #ffcc00; border: 1px solid #ffcc00; }
    .confidence-badge.low { background: rgba(255, 45, 85, 0.1); color: #ff2d55; border: 1px solid #ff2d55; }

    .action-group {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .btn-icon-minimal {
        background: var(--bg-inner);
        border: 1px solid var(--border-color);
        color: var(--text-dim);
        padding: 8px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-icon-minimal:hover {
        background: var(--btn-bg);
        color: var(--text-main);
        transform: translateY(-2px);
    }

    .btn-icon-minimal.accent:hover {
        color: var(--text-accent);
    }

    .empty-row {
        text-align: center;
        padding: 4rem !important;
        color: var(--text-dim);
        font-style: italic;
    }

    .no-evidence {
        font-size: 0.7rem;
        color: var(--text-dim);
        text-transform: uppercase;
        opacity: 0.5;
    }

    .animate-in { animation: auditFadeIn 0.5s ease-out; }
    @@keyframes auditFadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
