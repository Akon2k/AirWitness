@page "/multi"
@using Sentinel.Dashboard.Services
@using Sentinel.Dashboard.Models.Data
@using Sentinel.Dashboard.Components.Layout
@using System.IO
@inject RadioConfigService ConfigService
@inject WorkerOrchestrator Orchestrator
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Sentinel.Dashboard.Services.ThemeService Theme
@implements IDisposable
@rendermode InteractiveServer

<div class="dashboard-container @(isGridView ? "grid-mode" : "list-mode")">
    @* HEADER / STATS *@
    <div class="stats-header">
        <div class="stat-card">
            <div class="stat-icon running">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path></svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@radioTasks.Count(t => Orchestrator.IsRunning(t.StreamUrl))</span>
                <span class="stat-label">En Ejecución</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon idle">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@radioTasks.Count(t => !string.IsNullOrWhiteSpace(t.StreamUrl) && !Orchestrator.IsRunning(t.StreamUrl))</span>
                <span class="stat-label">En Espera</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon link-ok">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div class="stat-info">
                <span class="stat-value" style="color: var(--stat-online);">@radioTasks.Count(t => t.LinkStatus == "online")</span>
                <span class="stat-label">Enlaces OK</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon link-err">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <div class="stat-info">
                <span class="stat-value" style="color: var(--stat-offline);">@radioTasks.Count(t => t.LinkStatus == "offline")</span>
                <span class="stat-label">Enlaces Error</span>
            </div>
        </div>
    </div>

    @* BARRA DE HERRAMIENTAS *@
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-wrapper">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" class="search-input" placeholder="Buscar por medio o ciudad..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <select class="filter-select" @bind="filterCity">
                <option value="">Todas las ciudades</option>
                @foreach (var city in radioTasks.Where(t => !string.IsNullOrEmpty(t.City)).Select(t => t.City).Distinct())
                {
                    <option value="@city">@city</option>
                }
            </select>
            <select class="filter-select" @bind="filterStatus">
                <option value="all">Todos los estados</option>
                <option value="online">Online</option>
                <option value="offline">Offline</option>
            </select>
        </div>
        <div class="toolbar-right">
            <button class="btn-validate" @onclick='() => Nav.NavigateTo("/tools/doctor")' title="Asistente de reparación">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                LINK DOCTOR
            </button>
            <button class="btn-validate secondary" @onclick="ValidateAllLinks" title="Prueba rápida">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                CHECK RÁPIDO
            </button>
            <label class="btn-bulk-upload">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                CARGA MASIVA
                <InputFile OnChange="@HandleBulkPublicidadUpload" hidden accept=".mp3,.wav,.ogg" />
            </label>
            <div class="toolbar-divider"></div>
            <button class="btn-view @(isGridView ? "active" : "")" @onclick="() => isGridView = true" title="Vista Cuadrícula">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </button>
            <button class="btn-view @(!isGridView ? "active" : "")" @onclick="() => isGridView = false" title="Vista Lista">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </button>
        </div>
    </div>

    @if (isGridView)
    {
        <div class="grid-container">
            @foreach (var task in FilteredTasks)
            {
                var linkClass = task.LinkStatus == "online" ? "link-ok" : 
                               (task.LinkStatus == "offline" ? "link-err" : "");
                               
                <div class="radio-card @linkClass @(Orchestrator.IsRunning(task.StreamUrl) ? "status-online" : "status-offline")">
                    <div class="card-header">
                        <div class="media-cell">
                            <div class="media-icon">
                                <button class="btn-play-live @(task.IsListeningLive ? "playing" : "")" @onclick="() => ToggleLiveStream(task)" title="Escuchar/Detener en vivo">
                                    @if(task.IsListeningLive) { <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6 6h12v12H6z"></path></svg> }
                                    else { <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg> }
                                </button>
                            </div>
                            <div class="media-info">
                                @if (isConfigMode) { <input class="input-minimal media-name" @bind="task.Name" /> }
                                else { <span class="media-name">@task.Name</span> }
                                <div class="media-tag-container">
                                    <span class="media-tag">@task.Category</span>
                                    <span class="media-tag-frec">@task.Frequency</span>
                                </div>
                                @if (!isConfigMode) {
                                    <div style="font-size: 0.65rem; color: var(--text-dim); margin-top: 4px; font-family: 'Fira Code', monospace; background: rgba(0,0,0,0.2); padding: 2px 6px; border-radius: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px;">
                                        @task.StreamUrl
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="status-dot @(Orchestrator.IsRunning(task.StreamUrl) ? "online" : "offline")"></div>
                    </div>

                    <div class="card-body">
                        <div class="log-preview @(Orchestrator.IsRunning(task.StreamUrl) ? "scanning" : (task.IsScheduled ? "scheduled" : ""))">
                            @if(Orchestrator.IsRunning(task.StreamUrl) && string.IsNullOrEmpty(task.LastLog)) {
                                <span>ESCANEO ACTIVO...</span>
                            } else if (task.IsScheduled) {
                                <span class="text-amber">⏳ @task.LastLog</span>
                            } else {
                                @task.LastLog
                            }
                        </div>
                        
                        <div class="stats-row">
                            <div class="stat">
                                <span class="label">FIABILIDAD</span>
                                <span class="value">@task.BestConfidence.ToString("P0")</span>
                            </div>
                            <div class="stat">
                                <span class="label">HITS</span>
                                <span class="value">
                                    @task.MatchHistory.Count
                                    @if (task.MatchHistory.Any(m => !string.IsNullOrEmpty(m.EvidenceFile)))
                                    {
                                        <div class="evidence-pill">
                                            <a href="/evidencia/@task.MatchHistory.First(m => !string.IsNullOrEmpty(m.EvidenceFile)).EvidenceFile" target="_blank" download title="Última Evidencia">
                                                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                            </a>
                                        </div>
                                    }
                                </span>
                            </div>
                            <div class="stat">
                                <span class="label">LINK</span>
                                @if (task.IsValidating) { <span class="value link-validating">⌛ PROBANDO</span> }
                                else if (task.LinkStatus == "online") { <span class="value link-ok">● OK</span> }
                                else if (task.LinkStatus == "offline") { <span class="value link-err">✕ ERROR</span> }
                                else { <span class="value link-unknown">--</span> }
                            </div>
                        </div>

                        <div class="commercial-status-zone">
                            <div class="commercial-info">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                                @if (string.IsNullOrEmpty(task.MasterPath)) { <span class="no-commercial">SIN COMERCIAL CARGADO</span> }
                                else { <span class="commercial-name">@Path.GetFileName(task.MasterPath)</span> }
                            </div>
                            <div class="commercial-actions">
                                <button class="btn-mini-play @(task.IsListeningSample ? "playing" : "")" @onclick="() => PlaySample(task)" title="Escuchar/Detener Comercial">
                                    @if (task.IsListeningSample) { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M6 6h12v12H6z"></path></svg> }
                                    else { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg> }
                                </button>
                                <label class="btn-mini-upload" title="Subir Nuevo Comercial">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                    <InputFile OnChange="@(e => HandlePublicidadUpload(e, task))" hidden accept=".mp3,.wav,.ogg" />
                                </label>
                            </div>
                        </div>

                        @if (isConfigMode)
                        {
                            <div class="config-fields-inline">
                                <div class="field-item">
                                    <input placeholder="Nombre" @bind="task.Name" />
                                </div>
                                <div class="field-item">
                                    <input placeholder="Ciudad" @bind="task.City" />
                                </div>
                                <div class="field-item">
                                    <input placeholder="URL Streaming" @bind="task.StreamUrl" />
                                </div>
                            </div>
                        }
                    </div>

                    @if (!isConfigMode)
                    {
                        <div class="card-actions-row">
                            <button class="btn-action-main @(Orchestrator.IsRunning(task.StreamUrl) ? "active" : (task.IsScheduled ? "scheduled" : ""))" @onclick="() => ToggleTask(task)">
                                @if (Orchestrator.IsRunning(task.StreamUrl)) { <text>DETENER</text> }
                                else if (task.IsScheduled) { <text>CANCELAR</text> }
                                else { <text>INICIAR</text> }
                            </button>
                            <button class="btn-action-sec" @onclick="() => OpenScheduleModal(task)" title="Programación">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            </button>
                            <button class="btn-action-sec" @onclick="() => ShowTelemetry(task)" title="Ver Informe">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="table-container frosted-glass">
            <table class="premium-table-minimal">
                <thead>
                    <tr>
                        <th style="width: 220px;">MEDIO</th>
                        <th style="width: 100px;">ESTADO</th>
                        <th style="width: 130px;">UBICACIÓN</th>
                        <th style="width: 70px;">FIAB.</th>
                        <th style="width: 60px;">HITS</th>
                        <th style="width: 100px;">LINK</th>
                        <th>STREAMING SOURCE</th>
                        <th style="width: 280px; text-align: right;">PUBLICIDAD</th>
                        <th style="width: 160px; text-align: right;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in FilteredTasks)
                    {
                        <tr class="@(Orchestrator.IsRunning(task.StreamUrl) ? "status-online" : "status-offline")">
                            <td>
                                <div class="media-cell-minimal">
                                    <button class="btn-play-live-minimal @(playingLiveUrl == task.StreamUrl ? "playing" : "")" @onclick="() => ToggleLiveStream(task)">
                                        @if(playingLiveUrl == task.StreamUrl) { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg> }
                                        else { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg> }
                                    </button>
                                    <div class="media-info-minimal">
                                        <span class="media-name">@task.Name</span>
                                        <span class="media-tag">@task.Category | @task.Frequency</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="badge-status-minimal @(Orchestrator.IsRunning(task.StreamUrl) ? "online" : "offline")">
                                    <div class="dot"></div>
                                    @(Orchestrator.IsRunning(task.StreamUrl) ? "LIVE" : "IDLE")
                                </div>
                            </td>
                            <td>
                                <div class="meta-item-minimal">
                                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path></svg>
                                    <span>@task.City</span>
                                </div>
                            </td>
                            <td><span class="val-mini @(task.BestConfidence > 0.8m ? "high" : "low")">@(task.BestConfidence.ToString("P0"))</span></td>
                            <td><span class="val-mini-hits">@task.MatchHistory.Count</span></td>
                            <td>
                                <div class="link-status-minimal @(task.LinkStatus == "online" ? "ok" : "err")">
                                    <span class="link-dot"></span>
                                    @task.LinkStatus.ToUpper()
                                </div>
                            </td>
                            <td>
                                <div class="stream-link-minimal" title="@task.StreamUrl">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path></svg>
                                    <span class="url">@task.StreamUrl</span>
                                </div>
                            </td>
                            <td style="text-align: right;">
                                <div class="comm-zone-minimal">
                                    <div class="comm-info">
                                        @if (string.IsNullOrEmpty(task.MasterPath)) { <span class="no-audio">SIN AUDIO</span> }
                                        else { <span class="audio-name">@Path.GetFileName(task.MasterPath)</span> }
                                    </div>
                                    <div class="comm-actions">
                                        <button class="btn-action-tiny" @onclick="() => PlaySample(task)" title="Escuchar">
                                            @if(playingSampleUrl == task.MasterPath) { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg> }
                                            else { <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg> }
                                        </button>
                                        <label class="btn-action-tiny highlight">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                            <InputFile OnChange="@(e => HandlePublicidadUpload(e, task))" hidden accept=".mp3,.wav,.ogg" />
                                        </label>
                                    </div>
                                </div>
                            </td>
                            <td style="text-align: right;">
                                <div class="actions-group-minimal">
                                    <button class="btn-play-minimal @(Orchestrator.IsRunning(task.StreamUrl) ? "active" : "")" @onclick="() => ToggleTask(task)">
                                        @if (Orchestrator.IsRunning(task.StreamUrl)) { <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg> }
                                        else { <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg> }
                                    </button>
                                    <button class="btn-play-minimal" @onclick="() => OpenScheduleModal(task)" title="Horarios">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                    </button>
                                    <button class="btn-play-minimal" @onclick="() => ShowTelemetry(task)">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* MODAL DE PROGRAMACIÓN (ESTILO TIMELINE) *@
@if (showScheduleModal && selectedTaskForSchedule != null)
{
    <div class="sentinel-modal-overlay">
        <div class="schedule-timeline-modal animate-in">
            <div class="modal-header-premium">
                <div class="header-titles">
                    <h2>Programación: <span class="text-accent">@selectedTaskForSchedule.Name</span></h2>
                    <p class="subtitle">El motor iniciará 5 min antes de cada bloque.</p>
                </div>
                <button class="btn-close-circle" @onclick="CloseScheduleModal">&times;</button>
            </div>

            <div class="timeline-container-premium">
                <div class="timeline-scroll">
                    @for (int h = 6; h < 24; h++)
                    {
                        var hour = h;
                        var isActive = IsHourScheduled(hour);
                        <div class="timeline-block @(isActive ? "active" : "")" @onclick="() => ToggleHourBlock(hour)">
                            <div class="block-time">@(hour.ToString("D2")):00</div>
                            <div class="block-slot">
                                @if (isActive) { <div class="check-mark">✓</div> }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer-premium">
                <div class="status-summary">
                    <span class="status-pulse"></span>
                    Hitos marcados: <strong class="text-accent">@selectedTaskForSchedule.Schedules.Count</strong> bloques de 1 hora programados.
                </div>
                <div class="footer-actions">
                    <button class="btn-premium-close" @onclick="CloseScheduleModal">CERRAR</button>
                </div>
            </div>
        </div>
    </div>
}

@if (selectedRadioForTelemetry != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card frosted-glass animate-in" style="max-width: 900px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2 class="gradient-text">Telemetría en Vivo</h2>
                    <p style="font-size: 0.75rem; color: var(--text-dim); margin: 0;">Detalles acústicos de: <strong style="color: var(--text-accent);">@selectedRadioForTelemetry.Name</strong></p>
                </div>
                <button class="btn-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="telemetry-grid">
                    <div class="telemetry-stat-card">
                        <span class="label">Detecciones Hoy</span>
                        <span class="value accent">@selectedRadioForTelemetry.MatchHistory.Count</span>
                    </div>
                    <div class="telemetry-stat-card">
                        <span class="label">Picos de Confianza</span>
                        <span class="value">@selectedRadioForTelemetry.BestConfidence.ToString("P1")</span>
                    </div>
                    <div class="telemetry-stat-card">
                        <span class="label">Estado de Flujo</span>
                        <span class="value @(selectedRadioForTelemetry.LinkStatus == "online" ? "text-green" : "text-red")">
                            @(selectedRadioForTelemetry.LinkStatus?.ToUpper() ?? "VINCULADO")
                        </span>
                    </div>
                </div>

                <div class="table-card-inline">
                    <table class="premium-table-sm">
                        <thead>
                            <tr>
                                <th>HORA</th>
                                <th>INICIO RECORRIDO</th>
                                <th>FIN RECORRIDO</th>
                                <th>CONFIANZA</th>
                                <th style="text-align: right;">AUDITORÍA</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!selectedRadioForTelemetry.MatchHistory.Any())
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-dim); font-style: italic;">
                                        Sincronizando con el motor... esperando detección.
                                    </td>
                                </tr>
                            }
                                    @foreach (var match in selectedRadioForTelemetry.MatchHistory.OrderByDescending(m => m.Timestamp))
                                    {
                                        <tr>
                                            <td class="text-accent font-mono">@match.Timestamp</td>
                                            <td>---</td>
                                            <td>---</td>
                                            <td>
                                                <div class="confidence-bar-container">
                                                    <div class="confidence-bar" style="width: @(match.Confidence * 100)%"></div>
                                                    <span class="confidence-text">@(match.Confidence.ToString("P1"))</span>
                                                </div>
                                            </td>
                                            <td style="text-align: right;">
                                                @if (!string.IsNullOrEmpty(match.EvidenceFile))
                                                {
                                                    <a href="/evidencia/@match.EvidenceFile" target="_blank" class="btn-evidence-sm">
                                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                                        AUDIO
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-neon gray" @onclick="CloseModal">CERRAR</button>
            </div>
        </div>
    </div>
}

@code {
    private List<RadioTask> radioTasks = new();
    private string searchTerm = "";
    private string filterCity = "";
    private string filterStatus = "all";
    private bool isGridView = true;
    private string? playingLiveUrl = null;
    private string? playingSampleUrl = null;
    private RadioTask? selectedRadioForTelemetry = null;
    private bool isConfigMode = false;
    private bool showSaveSuccess = false;

    // Horarios
    private bool showScheduleModal = false;
    private RadioTask? selectedTaskForSchedule = null;

    // Optimizador UI
    private System.Timers.Timer? _uiTimer;
    private bool _needsRender = false;

    private IEnumerable<RadioTask> FilteredTasks => radioTasks
        .Where(t => string.IsNullOrEmpty(searchTerm) || t.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || t.City.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => string.IsNullOrEmpty(filterCity) || t.City == filterCity)
        .Where(t => filterStatus == "all" || (filterStatus == "online" && t.LinkStatus == "online") || (filterStatus == "offline" && t.LinkStatus == "offline"));

    protected override async Task OnInitializedAsync()
    {
        Theme.OnThemeChanged += StateHasChanged;
        radioTasks = await ConfigService.LoadConfigAsync();
        
        // Cargar horarios para cada radio
        foreach(var task in radioTasks)
        {
            if (int.TryParse(task.Id, out int id))
            {
                task.Schedules = await ConfigService.GetSchedulesAsync(id);
            }
        }

        Orchestrator.OnStatusChanged += () => InvokeAsync(StateHasChanged);
        
        Orchestrator.OnLog += (log, url) => {
            var task = radioTasks.FirstOrDefault(t => t.StreamUrl == url);
            if (task != null) task.LastLog = log;
            _needsRender = true; // Solo marcamos que necesita render, el timer hará el trabajo.
        };

        Orchestrator.OnNewResult += (match) => InvokeAsync(() => {
            var task = radioTasks.FirstOrDefault(t => t.StreamUrl == match.Source);
            if (task != null) {
                task.MatchHistory.Insert(0, match);
                if (match.Confidence > task.BestConfidence) task.BestConfidence = match.Confidence;
            }
            StateHasChanged(); // Los matches sí los renderizamos al instante por su importancia
        });

        // Iniciar timer de Debounce (Max 1 vez por segundo)
        _uiTimer = new System.Timers.Timer(1000);
        _uiTimer.Elapsed += (s, e) => {
            if (_needsRender) {
                _needsRender = false;
                InvokeAsync(StateHasChanged);
            }
        };
        _uiTimer.Start();
    }
    private void ToggleTask(RadioTask task)
    {
        if (Orchestrator.IsRunning(task.StreamUrl))
            Orchestrator.StopMonitor(task.StreamUrl);
        else
        {
            var masterTitle = string.IsNullOrEmpty(task.MasterPath) ? "Comercial Desconocido" : Path.GetFileNameWithoutExtension(task.MasterPath);
            Orchestrator.StartMonitor(task.MasterPath, task.StreamUrl, masterTitle, task.Name);
        }
    }

    private async Task ToggleLiveStream(RadioTask task)
    {
        if (playingLiveUrl == task.StreamUrl)
        {
            playingLiveUrl = null;
            await JS.InvokeVoidAsync("stopLiveAudio");
        }
        else
        {
            playingLiveUrl = task.StreamUrl;
            await JS.InvokeVoidAsync("playLiveAudio", task.StreamUrl);
        }
    }

    private async Task PlaySample(RadioTask task)
    {
        if (string.IsNullOrEmpty(task.MasterPath)) return;

        if (playingSampleUrl == task.MasterPath)
        {
            playingSampleUrl = null;
            await JS.InvokeVoidAsync("stopLiveAudio");
        }
        else
        {
            playingSampleUrl = task.MasterPath;
            // Usamos la misma función JS pero con el path del master
            var url = $"/masters/{Path.GetFileName(task.MasterPath)}";
            await JS.InvokeVoidAsync("playLiveAudio", url);
        }
    }

    private async Task ValidateAllLinks()
    {
        foreach (var task in radioTasks)
        {
            task.IsValidating = true;
            StateHasChanged();
            task.LinkStatus = await ConfigService.ValidateStreamUrlAsync(task.StreamUrl) ? "online" : "offline";
            task.IsValidating = false;
            StateHasChanged();
        }
    }

    private async Task HandlePublicidadUpload(InputFileChangeEventArgs e, RadioTask task)
    {
        var file = e.File;
        if (file != null)
        {
            var folder = Path.Combine("wwwroot", "masters");
            if (!Directory.Exists(folder)) Directory.CreateDirectory(folder);
            
            var path = Path.Combine(folder, file.Name);
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            using var fileStream = File.Create(path);
            await stream.CopyToAsync(fileStream);
            
            task.MasterPath = path;
            await ConfigService.SaveStationAsync(task);
            StateHasChanged();
        }
    }

    private async Task HandleBulkPublicidadUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var folder = Path.Combine("wwwroot", "masters");
            if (!Directory.Exists(folder)) Directory.CreateDirectory(folder);
            
            var path = Path.Combine(folder, file.Name);
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            using var fileStream = File.Create(path);
            await stream.CopyToAsync(fileStream);
            
            foreach(var task in radioTasks)
            {
                task.MasterPath = path;
                await ConfigService.SaveStationAsync(task);
            }
            StateHasChanged();
            await JS.InvokeVoidAsync("alert", "Comercial cargado masivamente a todas las radios.");
        }
    }

    private void ShowTelemetry(RadioTask task)
    {
        selectedRadioForTelemetry = task;
    }

    private void CloseModal()
    {
        selectedRadioForTelemetry = null;
    }

    private void OpenScheduleModal(RadioTask task)
    {
        selectedTaskForSchedule = task;
        showScheduleModal = true;
    }

    private void CloseScheduleModal()
    {
        showScheduleModal = false;
        selectedTaskForSchedule = null;
    }

    private bool IsHourScheduled(int hour)
    {
        if (selectedTaskForSchedule == null) return false;
        return selectedTaskForSchedule.Schedules.Any(s => s.StartTime.Hour == hour && s.IsActive);
    }

    private async Task ToggleHourBlock(int hour)
    {
        if (selectedTaskForSchedule == null) return;

        var existing = selectedTaskForSchedule.Schedules.FirstOrDefault(s => s.StartTime.Hour == hour);
        if (existing != null)
        {
            selectedTaskForSchedule.Schedules.Remove(existing);
            if (existing.Id > 0) await ConfigService.DeleteScheduleAsync(existing.Id);
        }
        else
        {
            var newSched = new MonitoringSchedule
            {
                RadioStationId = int.Parse(selectedTaskForSchedule.Id),
                StartTime = new TimeOnly(hour, 0),
                EndTime = new TimeOnly(hour, 59),
                DaysOfWeek = "1,2,3,4,5,6,7",
                IsActive = true
            };
            selectedTaskForSchedule.Schedules.Add(newSched);
            await ConfigService.SaveScheduleAsync(newSched);
        }
        StateHasChanged();
    }

    private async Task SaveConfig()
    {
        foreach(var task in radioTasks)
        {
            await ConfigService.SaveStationAsync(task);
        }
        isConfigMode = false;
        showSaveSuccess = true;
        StateHasChanged();
        await Task.Delay(2000);
        showSaveSuccess = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
        if (_uiTimer != null)
        {
            _uiTimer.Stop();
            _uiTimer.Dispose();
        }
        
        // Evitar audios fantasma al cambiar de vista
        if (!string.IsNullOrEmpty(playingLiveUrl) || !string.IsNullOrEmpty(playingSampleUrl))
        {
            _ = InvokeAsync(() => JS.InvokeVoidAsync("stopLiveAudio"));
        }
    }
}
