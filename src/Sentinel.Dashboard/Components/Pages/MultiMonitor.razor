<audio id="samplePlayer" hidden></audio>
<audio id="livePlayer" hidden></audio>

@code {
    private List<RadioTask> radioTasks = new();
    private bool isConfigMode = false;
    private bool showSaveSuccess = false;
    private RadioTask? selectedRadioForTelemetry = null;
    
    // Filtros y Vista
    private string searchTerm = "";
    private string filterCity = "";
    private string filterStatus = "all";
    private bool isGridView = true;
    private bool isLightMode = false;
    private string playingLiveUrl = "";
    private string playingSampleUrl = ""; // Nuevo estado para rastrear muestra comercial


    private IEnumerable<RadioTask> FilteredTasks => radioTasks.Where(t => 
        (string.IsNullOrWhiteSpace(searchTerm) || t.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || t.City.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(filterCity) || t.City == filterCity) &&
        (filterStatus == "all" || (filterStatus == "online" && Orchestrator.IsRunning(t.StreamUrl)) || (filterStatus == "offline" && !Orchestrator.IsRunning(t.StreamUrl)))
    );

    private void ToggleTheme() => isLightMode = !isLightMode;

    private async Task ToggleLiveStream(RadioTask task)
    {
        try
        {
            if (task.IsListeningLive)
            {
                task.IsListeningLive = false;
                StateHasChanged();
                await JS.InvokeVoidAsync("stopAudioById", "livePlayer");
            }
            else
            {
                foreach (var t in radioTasks) t.IsListeningLive = false;
                task.IsListeningLive = true;
                StateHasChanged();
                
                await JS.InvokeVoidAsync("stopAudioById", "livePlayer");
                await JS.InvokeVoidAsync("playAudioById", "livePlayer", task.StreamUrl);
            }
        }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        radioTasks = await ConfigService.LoadConfigAsync();
        
        Orchestrator.OnNewResult += HandleGlobalResult;
        Orchestrator.OnLog += HandleGlobalLog;
        Orchestrator.OnStatusChanged += StateChanged;
    }

    private async Task SaveConfig()
    {
        // Limpiamos URLs antes de guardar si detectamos patrones conocidos
        foreach (var task in radioTasks)
        {
            CleanUrl(task);
            if (!string.IsNullOrWhiteSpace(task.StreamUrl))
            {
                await ConfigService.SaveStationAsync(task);
            }
        }

        showSaveSuccess = true;
        StateHasChanged();
        await Task.Delay(3000);
        showSaveSuccess = false;
        StateHasChanged();
    }

    private void CleanUrl(RadioTask task)
    {
        if (string.IsNullOrWhiteSpace(task.StreamUrl)) return;

        var url = task.StreamUrl.Trim();

        // Patrón SonicPanel / TuStreaming
        if ((url.Contains("sonicpanel.cl") || url.Contains("tustreaming.cl")) && url.Contains("p="))
        {
            try {
                var uri = new Uri(url);
                var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
                if (query.TryGetValue("p", out var port)) {
                    var host = uri.Host;
                    task.StreamUrl = $"http://{host}:{port}/stream";
                }
            } catch {}
        }
        // Patrón TuneIn Embed
        else if (url.Contains("tunein.com/embed/player/"))
        {
            // TuneIn es difícil de extraer sin scraping pesado, pero al menos quitamos basura HTML
            task.StreamUrl = url.Split('?')[0];
        }
        
        // Limpieza de etiquetas HTML accidentales
        task.StreamUrl = task.StreamUrl.Replace("\">", "").Replace("</audio>", "").Split('"')[0].Trim();
    }

    private async Task ValidateAllLinks()
    {
        var client = ClientFactory.CreateClient();
        client.Timeout = TimeSpan.FromSeconds(6);

        foreach (var task in radioTasks.Where(t => 
            !string.IsNullOrWhiteSpace(t.StreamUrl) &&
            (t.StreamUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || 
             t.StreamUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))))
        {
            task.IsValidating = true;
            task.LinkStatus = "checking";
            StateHasChanged();

            try
            {
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
                using var response = await client.GetAsync(task.StreamUrl, HttpCompletionOption.ResponseHeadersRead, cts.Token);
                task.LinkStatus = (response.IsSuccessStatusCode || (int)response.StatusCode is 200 or 301 or 302) ? "online" : "offline";
            }
            catch (OperationCanceledException)
            {
                task.LinkStatus = "offline"; // timeout = sin respuesta = offline
            }
            catch
            {
                task.LinkStatus = "offline";
            }

            task.IsValidating = false;
            StateHasChanged();
        }
    }

    private void ShowTelemetry(RadioTask task)
    {
        selectedRadioForTelemetry = task;
    }

    private void CloseModal()
    {
        selectedRadioForTelemetry = null;
    }

    private async Task PlaySample(RadioTask task)
    {
        if (string.IsNullOrWhiteSpace(task.MasterPath)) return;
        
        try
        {
            if (task.IsListeningSample)
            {
                task.IsListeningSample = false;
                StateHasChanged();
                await StopSample();
            }
            else
            {
                foreach (var t in radioTasks) t.IsListeningSample = false;
                task.IsListeningSample = true;
                StateHasChanged();

                var url = task.MasterPath;
                if (url.Contains("wwwroot"))
                {
                    url = url.Split("wwwroot")[1].Replace("\\", "/");
                }
                
                await JS.InvokeVoidAsync("playAudioById", "samplePlayer", url);
            }
        }
        catch { }
    }

    private async Task StopSample()
    {
        try
        {
            await JS.InvokeVoidAsync("stopAudioById", "samplePlayer");
            foreach (var t in radioTasks) t.IsListeningSample = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandlePublicidadUpload(InputFileChangeEventArgs e, RadioTask task)
    {
        task.IsUploading = true;
        StateHasChanged();

        try
        {
            var radioSlug = GetSlug(task.Name);
            var folder = Path.Combine(Environment.CurrentDirectory, "wwwroot", "assets", radioSlug);
            
            if (!Directory.Exists(folder)) Directory.CreateDirectory(folder);

            var path = Path.Combine(folder, e.File.Name);
            using (var fileStream = new FileStream(path, FileMode.Create))
            {
                await e.File.OpenReadStream(50 * 1024 * 1024).CopyToAsync(fileStream); // 50MB max
            }
            
            // Guardamos la ruta relativa para el orquestador y la absoluta para Blazor si es necesario
            task.MasterPath = path;
            
            // Mostrar toast de éxito
            showSaveSuccess = true;
            await Task.Delay(1500);
            showSaveSuccess = false;
        }
        catch (Exception ex)
        {
            task.LastLog = $"Error subiendo: {ex.Message}";
        }
        finally
        {
            task.IsUploading = false;
            StateHasChanged();
        }
    }

    private string GetSlug(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "radio-anonima";
        return text.ToLower()
                   .Replace(" ", "-")
                   .Replace("ñ", "n")
                   .Where(c => char.IsLetterOrDigit(c) || c == '-')
                   .Aggregate("", (a, b) => a + b);
    }

    private void StartAllTasks()
    {
        foreach (var task in radioTasks)
        {
            if (!string.IsNullOrWhiteSpace(task.StreamUrl) && !string.IsNullOrWhiteSpace(task.MasterPath) && !Orchestrator.IsRunning(task.StreamUrl))
            {
                task.MatchHistory.Clear();
                task.BestConfidence = 0;
                task.LastLog = "Iniciando (Global)...";
                Orchestrator.StartMonitor(task.MasterPath, task.StreamUrl);
            }
        }
    }

    private void StopAllTasks()
    {
        Orchestrator.StopAll();
        foreach (var task in radioTasks)
        {
            task.LastLog = "Detenido globalmente.";
        }
        StateHasChanged();
    }

    private void ToggleTask(RadioTask task)
    {
        if (string.IsNullOrWhiteSpace(task.StreamUrl)) return;

        if (Orchestrator.IsRunning(task.StreamUrl))
        {
            Orchestrator.StopMonitor(task.StreamUrl);
        }
        else
        {
            if (string.IsNullOrWhiteSpace(task.MasterPath))
            {
                task.LastLog = "⚠ Falta el audio publicitario. Ve a Configurar → sube el .mp3 del comercial.";
                StateHasChanged();
                return;
            }
            task.MatchHistory.Clear();
            task.BestConfidence = 0;
            task.LastLog = "Iniciando...";
            Orchestrator.StartMonitor(task.MasterPath, task.StreamUrl);
        }
    }

    private void HandleGlobalResult(MatchResult result)
    {
        var task = radioTasks.FirstOrDefault(t => t.StreamUrl == result.Source);
        if (task != null)
        {
            if (result.Confidence > task.BestConfidence) task.BestConfidence = result.Confidence;
            if (result.Match) task.MatchHistory.Insert(0, result);
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleGlobalLog(string message, string url)
    {
        var task = radioTasks.FirstOrDefault(t => t.StreamUrl == url);
        if (task != null)
        {
            task.LastLog = message;
            InvokeAsync(StateHasChanged);
        }
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Orchestrator.OnNewResult -= HandleGlobalResult;
        Orchestrator.OnLog -= HandleGlobalLog;
        Orchestrator.OnStatusChanged -= StateChanged;
    }
}
