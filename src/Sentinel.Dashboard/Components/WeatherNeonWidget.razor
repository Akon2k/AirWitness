@using System.Threading
@implements IDisposable

<div class="weather-neon-widget">
    <div class="weather-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- Simulated Cloud and Sun -->
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M6.34 17.66l-1.41 1.41"></path>
            <path d="M19.07 4.93l-1.41 1.41"></path>
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M16 14 A 5 5 0 0 1 8 14 A 3 3 0 0 1 8 8 A 4 4 0 0 1 12 5 A 4.5 4.5 0 0 1 16 14 Z" fill="rgba(30, 40, 50, 0.7)" stroke="none"></path>
            <path d="M16 14 A 5 5 0 0 1 8 14 A 3 3 0 0 1 8 8 A 4 4 0 0 1 12 5 A 4.5 4.5 0 0 1 16 14" stroke="#00f3ff"></path>
        </svg>
    </div>
    <div class="weather-info">
        <span class="weather-temp">@currentTemp°C</span>
        <span class="weather-desc">STGO <br/> ESTABLE</span>
    </div>

    <div class="widget-divider"></div>

    <div class="restriction-info">
        <span class="restrict-title">
            <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 3px;"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
            RESTRICCIÓN
        </span>
        <div class="restrict-plates">
            @foreach (var digit in GetRestrictedDigits())
            {
                <span class="plate-badge">@digit</span>
            }
            @if (!GetRestrictedDigits().Any())
            {
                <span class="plate-badge" style="font-size: 8px; opacity: 0.7;">LIBRE</span>
            }
        </div>
    </div>

    <div class="weather-status">
        <span class="pulse-dot"></span> EN VIVO
    </div>
</div><style>
    .weather-neon-widget {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        background: transparent;
        border: none;
        border-radius: 0;
        padding: 0;
        margin: 0;
        box-shadow: none;
        position: relative;
        gap: 16px;
        min-width: 200px;
        transition: all 0.3s ease;
    }

    .weather-icon {
        flex: 0 0 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .weather-icon svg {
        width: 100%;
        height: 100%;
        stroke: var(--text-dim);
        filter: none;
    }
    
    .weather-icon svg path[stroke="#00f3ff"] {
        stroke: var(--text-accent);
        filter: none;
    }

    .weather-info {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .weather-temp {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: var(--text-main);
        text-shadow: none;
        line-height: 1;
    }

    .weather-desc {
        font-size: 9px;
        font-weight: 700;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-top: 2px;
    }

    .widget-divider {
        width: 1px;
        height: 28px;
        background: var(--border-color);
        opacity: 0.5;
    }

    .restriction-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-right: 10px;
        border-right: 1px solid var(--border-color);
        margin-right: 10px;
    }

    .restrict-title {
        font-size: 8px;
        font-weight: 800;
        color: var(--text-dim);
        letter-spacing: 0.8px;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .restrict-plates {
        display: flex;
        gap: 4px;
    }

    .plate-badge {
        font-family: 'Space Grotesk', monospace;
        font-size: 11px;
        font-weight: 700;
        background: var(--btn-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        border-radius: 3px;
        padding: 1px 5px;
        line-height: 1.2;
    }

    .weather-status {
        font-size: 7px;
        font-weight: 900;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 4px;
        letter-spacing: 0.5px;
        margin-left: -5px;
    }

    .weather-status .pulse-dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background-color: var(--stat-online);
        animation: subtle-pulse 2s infinite ease-in-out;
    }

    @@keyframes subtle-pulse {
        0% { opacity: 0.4; transform: scale(0.8); }
        50% { opacity: 1; transform: scale(1.1); }
        100% { opacity: 0.4; transform: scale(0.8); }
    }
</style>

@code {
    private decimal currentTemp = 18.5m;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        // Simular cambios sutiles de temperatura viva cada 15 segundos para dar realismo a la herramienta
        _timer = new Timer(UpdateWeather, null, 0, 15000);
    }

    private void UpdateWeather(object? state)
    {
        var random = new Random();
        var change = (decimal)(random.NextDouble() * 0.4 - 0.2); // Fluctúa +/- 0.2
        currentTemp = Math.Round(currentTemp + change, 1);
        InvokeAsync(StateHasChanged);
    }

    private int[] GetRestrictedDigits()
    {
        var today = DateTime.Today.DayOfWeek;
        return today switch
        {
            DayOfWeek.Monday => new[] { 4, 5 },
            DayOfWeek.Tuesday => new[] { 6, 7 },
            DayOfWeek.Wednesday => new[] { 8, 9 },
            DayOfWeek.Thursday => new[] { 0, 1 },
            DayOfWeek.Friday => new[] { 2, 3 },
            _ => Array.Empty<int>() // Fines de semana
        };
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
